    class GestorBotones implements ActionListener{       
        @Override
        public void actionPerformed(ActionEvent evento) {
            CardLayout local = (CardLayout)(panelInterfaces.getLayout());
            // GET SOURCE
            String literal = evento.getActionCommand();
            switch (literal){
                case "NUEVA PARTIDA" -> {
                    if(partidaFinalizada == true){
                        tablero.borrar();
                        tablero.setInsercion(false);
                        String[] literalesNuevaPartida = {"NOMBRE JUGADOR"};
                        literalesNuevaPartida = new LTGraficos(ventana,literalesNuevaPartida).getDatosTexto();
                        if (literalesNuevaPartida!=null) {
                            nombre_jugador = literalesNuevaPartida[0];
                                                
                            jugador2.setText(nombre_jugador + "   ");
                            puntuacion2.setText(String.valueOf(puntuacion) + " puntos   ");
                        }
                        if (!"".equals(nombre_jugador)){
                            local.show(panelInterfaces, "PANEL 1");
                            // delay tiempoPartida*1000 -> tarda tiempoPartida en avanzar un uno porciento
                            cronometro = new Timer(tiempoPartida*10,new GestorTiempo());
                            cronometro.start();
                            partidaFinalizada = false;
                        }
                    } else {
                        JOptionPane.showMessageDialog(null,"ANTES DEBES TERMINAR LA PARTTIDA EN CURSO");
                    }                    
                }
                
                case "ROTAR FORMA" -> {
                    tablero.rotarForma();
                    puntuacion = puntuacion + rotarForma;
                    // actualizamos el valor que se muestra 
                    puntuacion2.setText(String.valueOf(puntuacion) + " puntos   ");
                    panelJuego.repaint();
                }
                
                case "NUEVA FORMA" -> {
                    tablero.cambiarForma();
                    puntuacion = puntuacion + nuevaForma;
                    // actualizamos el valor que se muestra 
                    puntuacion2.setText(String.valueOf(puntuacion) + " puntos   ");
                    panelJuego.repaint();
                }
                    
                case "CONFIGURACIÓN" -> {
                    if(partidaFinalizada == true){
                        String[] menu = {"CONFIGURACIÓN ESPECÍFICA JUEGO", "MODIFICAR TIEMPO PARTIDA","NADA"};
                        int opcion;
                        UIManager.put("OptionPane.messageForeground", java.awt.Color.BLACK);
                        do {
                            opcion = JOptionPane.showOptionDialog(null,
                                    "¿QUÉ DESEA REALIZAR?",
                                    "CONFIGURACIÓN",
                                    JOptionPane.YES_NO_CANCEL_OPTION,
                                    JOptionPane.QUESTION_MESSAGE,
                                    null,
                                    menu,
                                    menu[0]);
                        
                            switch (opcion){
                                case 0 -> {
                                    String[] literalesConfiguracion1 = {"PUNTUACIÓN CASILLAS FORMAS ELIMINADAS [1p]",
                                        "PUNTUACIÓN ROTAR FORMA [-1p]",
                                        "PUNTUACIÓN NUEVA FORMA [-5p]",
                                        "IMAGEN CASILLAS FORMAS [verde.JPG]"};
                                    literalesConfiguracion1 = new LTGraficos(ventana,literalesConfiguracion1, false).getDatosTexto();
                                    if (literalesConfiguracion1[0]!=null){
                                        try {
                                            formaEliminada = Integer.parseInt(literalesConfiguracion1[0]);
                                        } catch (NumberFormatException error){
                                        }
                                    }
                                    if (literalesConfiguracion1[1]!=null){
                                        try {
                                            rotarForma = Integer.parseInt(literalesConfiguracion1[1]);
                                        } catch (NumberFormatException error){
                                        }
                                    }
                                    if (literalesConfiguracion1[2]!=null){
                                        try {
                                            nuevaForma = Integer.parseInt(literalesConfiguracion1[2]);
                                            System.out.println(nuevaForma);
                                        } catch (NumberFormatException error){
                                        }
                                    }
                                    opcion = -1;
                                }
                                case 1 -> {
                                    String[] literalesConfiguracion2 = {"TIEMPO DE PARTIDA [30 segundos]"};
                                    literalesConfiguracion2 = new LTGraficos(ventana,literalesConfiguracion2,false).getDatosTexto();
                                    if (literalesConfiguracion2[0]!=null){
                                        try {
                                            tiempoPartida = Integer.parseInt(literalesConfiguracion2[0]);
                                            System.out.println(tiempoPartida);
                                        } catch (NumberFormatException error){
                                        }
                                    }
                                    opcion = -1;
                                }
                                case 2 -> opcion = -1;
                            }
                        }while(opcion != (- 1) );
                    } else {
                        JOptionPane.showMessageDialog(null,"ANTES DEBES TERMINAR LA PARTTIDA EN CURSO");
                    }
                }
                    
                case "HISTORIAL" -> {
                    if(partidaFinalizada == true){
                        local.show(panelInterfaces, "PANEL 3");
                        // leemos el fichero del historial y lo mostramos 
                        Historial historial;
                        //HistorialObjetoFicherosLectura ficheroLectura;
                        FicheroElementoInOut fichero;
                        String todoHistorial = "";
                        try{
                            fichero = new FicheroElementoInOut("partidasTetrisUIB.dat");
                            try{
                                historial = fichero.lectura();
                                while(historial!=null){
                                    System.out.println(historial.toString());
                                    todoHistorial = todoHistorial + historial + "\n";
                                    // leemos el siguiente elemento
                                    historial = fichero.lectura();
                                }
                            }catch (Exception error) {
                                System.err.println("ERROR: FICHERO INEXISTENTE");
                            }finally {
                                try {
                                    //cierre del enlace con el fichero
                                    fichero.cierre();
                                }catch (IOException error) {
                                    System.out.println("ERROR EN EL CIERRE DEL FICHERO");
                                }
                            }   
                        }catch (Exception error){
                            System.err.println("ERROR: FICHERO INEXISTENTE");
                        } 
                        historialPartida.setText("\n\n" + todoHistorial);
                    } else {
                        JOptionPane.showMessageDialog(null,"ANTES DEBES TERMINAR LA PARTTIDA EN CURSO");
                    }
                }
                    
                case "INFORMACIÓN" -> {
                    if(partidaFinalizada == true){
                        local.show(panelInterfaces, "PANEL 2");
                    } else {
                        JOptionPane.showMessageDialog(null,"ANTES DEBES TERMINAR LA PARTTIDA EN CURSO");
                    }                    
                }
                
                case "SALIR" -> {
                    System.exit(0);
                }
            }
        }
    }
    
    class GestorTiempo implements ActionListener{ 
        @Override
        public void actionPerformed(ActionEvent evento) {
            CardLayout local = (CardLayout)(panelInterfaces.getLayout());
            if(evento.getSource()==cronometro) {
                int valor=barraTemporal.getValue();
                if(valor<valorMaximo){
                    barraTemporal.setValue(++valor);
                } else{
                    cronometro.restart();
                    cronometro.stop();
                    // después de que acabe el tiempo escribimos en el fichero de historial
                    Historial historial = new Historial();
                    //HistorialObjetoFicherosEscritura fichero;
                    FicheroElementoInOut fichero;
                    try{
                        fichero = new FicheroElementoInOut("partidasTetrisUIB.dat");
                        historial.lectura(nombre_jugador, tiempoPartida, puntuacion);
                        fichero.escritura(historial);
                        //cierre del enlace con el fichero
                        fichero.cierre();
                    }catch (Exception error) {
                        System.err.println("ERROR EN LA CREACIÓN DEL FICHERO");
                    }
                    JOptionPane.showMessageDialog(null,"HAS OBTENIDO UNA PUNTUACIÓN DE " + puntuacion);
                    barraTemporal.setValue(0);
                    local.show(panelInterfaces, "PANEL 0");
                    puntuacion=0;
                    nombre_jugador = "";
                    partidaFinalizada = true;
                }
            }
        }
    }     
    
    private void eventosTablero(){
        // añadimos un MouseListener al tablero
        tablero.addMouseListener(new MouseListener(){
            @Override
            public void mouseClicked(MouseEvent e) {
            }

            @Override
            public void mousePressed(MouseEvent e) {
                // obtenemos las coordenadas de clic del raton
                int x=e.getX();                  
                int y=e.getY();

                // comprobamos si el clic se ha hecho dentro de la zona 
                if ((!DESPLAZAMIENTO)&&(x>=COORDENADA_X_INICIAL)
                                   &&(x<=COORDENADA_X_INICIAL+90)
                                   &&(y>=COORDENADA_Y_INICIAL)
                                   &&(y<=COORDENADA_Y_INICIAL+90)) {
                    DESPLAZAMIENTO=true;
                    tablero.setInsercion(true);               
                    tablero.repaint(); 
                }else {
                    tablero.setInsercion(false);
                    tablero.repaint();
                      }       
            }

            @Override
            public void mouseReleased(MouseEvent e) {
                // obtenemos las coordenadas de clic del raton
                int x=e.getX();                  
                int y=e.getY(); 
                int x2=(x+tablero.getDesfaseX())/30;
                int y2=(y+tablero.getDesfaseY())/30;
                
                // comprobamos si la ficha se ha soltado en una posición válida del tablero
                if ((DESPLAZAMIENTO) && x2>=-1 && x2<=18 && y2>=-1 && y2<=17){
                    if(x < 30){
                        x2 = x2-1;
                    }
                    if(y < 40){
                        y2 = y2-1;
                    }
                    // matriz basada en las coordenadas
                    Casilla [][] matriz = tablero.extraerMatriz(x2,y2);
                    // comprobamso si la matriz es compatible con el tablero
                    if(tablero.compatibilidad(matriz)){
                        for (int fila=0; fila <3; fila++) {
                            for (int columna=0;columna<3;columna++) {
                                if(tablero.getEstadoFiguras(fila, columna)==true){
                                    // marcamos la posicion en el tablero como ocupada
                                    tablero.setOcupadaTablero((fila+y2)+2, (columna+x2)+1);
                                }
                            }          
                        }  
                        tablero.cambiarForma();
                    }
                        
                }
                // verificamos las filas y las columnas después de soltar la ficha
                verificarFilasColumnas();
                tablero.setCoordX(COORDENADA_X_INICIAL);
                tablero.setCoordY(COORDENADA_Y_INICIAL);
                tablero.setInsercion(false);
                tablero.repaint();
                DESPLAZAMIENTO=false;
                
            }

            @Override
            public void mouseEntered(MouseEvent e) {}

            @Override
            public void mouseExited(MouseEvent e) {}
        
        });
          
        // añadimos un MouseMotionListener al tablero   
        tablero.addMouseMotionListener(new MouseMotionListener(){
            @Override
            public void mouseDragged(MouseEvent e) {
            // si hay desplazamiento actualizamos las coordenadas del ratón y repintamos el tablero
            if (DESPLAZAMIENTO) {
                tablero.setCoordX(e.getX());
                tablero.setCoordY(e.getY());
                tablero.repaint();
            }
        }

            @Override
           public void mouseMoved(MouseEvent e) {}
        
        });
    }
    
    private void verificarFilasColumnas(){
        // verificamos des de la fila 2 hasta la penultima
        for (int fila = 2; fila < tablero.getNumCasillas()-2; fila++) {
            boolean filaCompleta = true;
            // comprobamos si todas las casillas de la fila están ocupadas
            for (int columna = 2; columna < tablero.getNumCasillas()-2; columna++) {
                if (!tablero.getEstadoCasilla(fila, columna)) {
                    filaCompleta = false;
                    break;
                }
            }
            
            // si todas están ocupadas actualizamos la puntuacion y vaciamos las casillas
            if (filaCompleta) {
                if(formaEliminada>=0){
                    puntuacion=puntuacion+formaEliminada*18;
                }else {
                    puntuacion=puntuacion-formaEliminada*18;
                }
                    puntuacion2.setText(String.valueOf(puntuacion) + " puntos   ");
                for (int columna = 2; columna < tablero.getNumCasillas()-2; columna++) {
                    tablero.setLiberadaTablero(fila, columna);
                }
            }
        }

        // Verificar columnas igual que hemos hecho con las filas
        for (int columna = 2; columna < tablero.getNumCasillas()-2; columna++) {
            boolean columnaCompleta = true;
            for (int fila = 2; fila < 20; fila++) {
                if (!tablero.getEstadoCasilla(fila, columna)) {
                    columnaCompleta = false;
                    break;
                }
            }
            if (columnaCompleta) {
                if(formaEliminada>=0){
                    puntuacion=puntuacion+formaEliminada*18;
                }else{
                    puntuacion=puntuacion-formaEliminada*18;
                }
                puntuacion2.setText(String.valueOf(puntuacion) + " puntos   ");
                for (int fila = 2; fila <  tablero.getNumCasillas()-2; fila++) {
                    tablero.setLiberadaTablero(fila, columna);
                }
            }
        }   
    }
}
